<div id="admin-content">
  <div class="container">
    <div class="row">
      <div class="col-md-12">
        <h1 class="adin-heading"> Update Category</h1>
      </div>
      <div class="col-md-6 mx-auto">
        <div class="card">
          <h5 class="card-header">Update Category</h5>
          <div class="card-body">
            <!-- Form Start -->
            <form action="/admin/update-category/<%= user._id %>" method="POST" autocomplete="off">
              <div class="mb-3">
                <label for="" class="form-label">Category Name</label>
                <input type="text" name="name" value="<%= user.name%>" class="form-control" placeholder="Category Name"
                  required>
              </div>
              <div class="mb-3">
                <label for="" class="form-label">Description</label>
                <textarea name="description" class="form-control"><%= user.description%></textarea>
              </div>
              <input type="submit" name="save" class="btn btn-primary" value="Update" required />
            </form>
            <!-- /Form End -->
            <!-- Include error messages partial -->
             <div class="mt-3">
              <%- include('../partials/error') %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>